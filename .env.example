# ===========================================
# DATABASE CONFIGURATION (Neon PostgreSQL)
# ===========================================

# Neon connection string with connection pooling (used by the app at runtime)
# Get this from your Neon project dashboard -> Connection Details -> Pooled connection
DATABASE_URL="postgresql://[user]:[password]@[endpoint]-pooler.neon.tech/[dbname]?sslmode=verify-full"

# Direct (non-pooled) connection URL — required by Prisma migrations
# Get this from Neon dashboard -> Connection Details -> Direct connection
DIRECT_URL="postgresql://[user]:[password]@[endpoint].neon.tech/[dbname]?sslmode=verify-full"

# ===========================================
# JWT AUTHENTICATION
# ===========================================
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
# Access token expiry — keep short (15m recommended). Refresh tokens extend sessions.
JWT_EXPIRES_IN="15m"

# ===========================================
# ENCRYPTION (REQUIRED)
# ===========================================
# 32+ character random string — used to encrypt stored AI API keys
# Generate: openssl rand -hex 32
ENCRYPTION_KEY="your-32-character-encryption-key-here"

# ===========================================
# CACHE (Redis — optional, falls back to in-memory)
# ===========================================
# REDIS_URL=redis://localhost:6379
# Production example: REDIS_URL=redis://user:password@redis.example.com:6379

# ===========================================
# ERROR TRACKING (Sentry)
# ===========================================
# Get DSN from https://sentry.io — leave empty to disable
SENTRY_DSN=""

# ===========================================
# EMAIL SERVICE (Resend)
# ===========================================
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="noreply@relon.com"

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
# Frontend URL (for password reset links, email templates)
FRONTEND_URL="http://localhost:3000"

# CORS Origin (comma-separated for multiple origins)
CORS_ORIGIN="http://localhost:3000"
# Production example:
# CORS_ORIGIN="https://yourdomain.com,https://www.yourdomain.com"

# ===========================================
# AI PROVIDER CONFIGURATION
# ===========================================
OPENAI_API_KEY="your-openai-api-key"
AI_DEFAULT_PROVIDER="OPENAI"

# Optional: Add other AI providers
# ANTHROPIC_API_KEY="your-anthropic-api-key"
# GEMINI_API_KEY="your-gemini-api-key"

# ===========================================
# GOOGLE CLOUD PLATFORM (GCP) STORAGE
# ===========================================
GCP_PROJECT_ID="your-gcp-project-id"
GCP_STORAGE_BUCKET="your-bucket-name"

# Local Development: Path to service account key file
GCP_SERVICE_ACCOUNT_KEY_PATH="./gcp-service-account-key.json"

# Production (Cloud Run): Use Workload Identity (no key file needed)
# Leave GCP_SERVICE_ACCOUNT_KEY_PATH empty or unset when using Workload Identity

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=4000
NODE_ENV="development"
# Production: NODE_ENV="production"

# ===========================================
# STRIPE BILLING
# ===========================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID_STARTER=price_starter_monthly
STRIPE_PRICE_ID_GROWTH=price_growth_monthly
STRIPE_PRICE_ID_SCALE=price_scale_monthly
STRIPE_PRICE_ID_STARTER_ANNUAL=price_starter_annual
STRIPE_PRICE_ID_GROWTH_ANNUAL=price_growth_annual
STRIPE_PRICE_ID_SCALE_ANNUAL=price_scale_annual

# ===========================================
# Paystack Billing
# ===========================================
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# Paystack Plan Codes (create these in your Paystack dashboard)
# Format: PAYSTACK_PLAN_CODE_{PLAN}_{CURRENCY}
PAYSTACK_PLAN_CODE_STARTER_GHS=PLN_xxxxxxxxxxxxx
PAYSTACK_PLAN_CODE_GROWTH_GHS=PLN_xxxxxxxxxxxxx
PAYSTACK_PLAN_CODE_SCALE_GHS=PLN_xxxxxxxxxxxxx
PAYSTACK_PLAN_CODE_STARTER_NGN=PLN_xxxxxxxxxxxxx
PAYSTACK_PLAN_CODE_GROWTH_NGN=PLN_xxxxxxxxxxxxx
PAYSTACK_PLAN_CODE_SCALE_NGN=PLN_xxxxxxxxxxxxx

# ===========================================
# Google OAuth
# ===========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ===========================================
# Microsoft OAuth
# ===========================================
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_CALLBACK_URL=http://localhost:4000/api/auth/microsoft/callback

# ===========================================
# QuickBooks Integration
# ===========================================
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:4000/api/quickbooks/callback
QB_ENVIRONMENT=sandbox
QB_WEBHOOK_VERIFIER_TOKEN=
