  serviceItem    ServiceItem                 @relation(fields: [serviceItemId], references: [id], onDelete: Cascade)
  roleEstimates  ServiceItemRoleEstimate[]
  timeEntries    TimeEntry[]

  @@index([serviceItemId])
  @@map("service_item_subtasks")
}

model ServiceItemRoleEstimate {
  id             String   @id @default(uuid())
  subtaskId      String
  role           String
  estimatedHours Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subtask ServiceItemSubtask @relation(fields: [subtaskId], references: [id], onDelete: Cascade)

  @@unique([subtaskId, role])
  @@index([subtaskId])
  @@map("service_item_role_estimates")
}

model QuoteSettings {
  id                  String   @id @default(uuid())
  organizationId      String   @unique
  companyName         String   @default("")
  companyAddress      String?
  companyPhone        String?
  companyEmail        String?
  companyWebsite      String?
  logoUrl             String?
  quoteNumberPrefix   String   @default("Q")
  nextQuoteNumber     Int      @default(1)
  defaultTaxRate      Decimal  @db.Decimal(5, 2) @default(0)
  defaultValidityDays Int      @default(30)
  defaultCurrency     String   @default("USD")
  defaultNotes        String?
  defaultTerms        String?
  accentColor         String   @default("#b8873a")
  showTaxLine         Boolean  @default(true)
  showDiscountLine    Boolean  @default(false)
  showSignatureBlock  Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quotes       Quote[]

  @@map("quote_settings")
}

model Quote {
  id                 String    @id @default(uuid())
  organizationId     String
  quoteNumber        Int
  settingsId         String?
  leadId             String?
  clientId           String?
  projectId          String?
  status             String    @default("DRAFT")
  validUntil         DateTime?
  notes              String?   @db.Text
  termsAndConditions String?   @db.Text
  taxRate            Decimal   @db.Decimal(5, 2) @default(0)
  discount           Decimal   @db.Decimal(10, 2) @default(0)
  subtotal           Decimal   @db.Decimal(10, 2) @default(0)
  taxAmount          Decimal   @db.Decimal(10, 2) @default(0)
  total              Decimal   @db.Decimal(10, 2) @default(0)
  currency           String    @default("USD")
  sentAt             DateTime?
  acceptedAt         DateTime?
  rejectedAt         DateTime?
  rejectionReason    String?
  createdById        String

  // QuickBooks integration
  qbInvoiceId        String?
  qbPaymentStatus    String? // 'unpaid', 'partial', 'paid', 'voided'

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  settings     QuoteSettings? @relation(fields: [settingsId], references: [id], onDelete: SetNull)
  lead         Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  client       Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project      Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy    User           @relation("QuoteCreator", fields: [createdById], references: [id], onDelete: Restrict)
  lineItems    QuoteLineItem[]

  @@unique([organizationId, quoteNumber])
  @@index([organizationId])
  @@index([leadId])
  @@index([clientId])
  @@index([projectId])
  @@map("quotes")
}

model QuoteLineItem {
  id            String   @id @default(uuid())
  quoteId       String
  description   String
  quantity      Decimal  @db.Decimal(10, 2) @default(1)
  unitPrice     Decimal  @db.Decimal(10, 2) @default(0)
  lineTotal     Decimal  @db.Decimal(10, 2) @default(0)
  taxable       Boolean  @default(true)
  sortOrder     Int      @default(0)
  serviceItemId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  quote       Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  serviceItem ServiceItem? @relation(fields: [serviceItemId], references: [id])

  @@index([quoteId])
  @@map("quote_line_items")
}

model TimeEntry {
  id                   String   @id @default(uuid())
  organizationId       String
  userId               String
  projectId            String?
  serviceItemId        String?
  serviceItemSubtaskId String?
  date                 DateTime
  hours                Decimal  @db.Decimal(10, 2)
  description          String?
  billable             Boolean  @default(true)
  hourlyRate           Decimal? @db.Decimal(10, 2)
  totalCost            Decimal? @db.Decimal(10, 2)
  source               String   @default("manual")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization         Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                 User                @relation("UserTimeEntries", fields: [userId], references: [id], onDelete: Restrict)
  project              Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  serviceItem          ServiceItem?        @relation(fields: [serviceItemId], references: [id], onDelete: SetNull)
  serviceItemSubtask   ServiceItemSubtask? @relation(fields: [serviceItemSubtaskId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([projectId])
  @@index([date])
  @@map("time_entries")
}

model UserRate {
