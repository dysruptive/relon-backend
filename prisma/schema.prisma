model WorkflowRule {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  trigger        String   // "LEAD_STAGE_CHANGED" | "LEAD_CREATED" | "TASK_DUE" | "PROJECT_STATUS_CHANGED" | "DAYS_SINCE_CONTACT"
  conditions     Json     // { logic: 'AND'|'OR', rules: [{ field, operator, value }] }
  actions        Json     // [{ type, config }]
  isActive       Boolean  @default(true)
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User               @relation("WorkflowRuleCreator", fields: [createdById], references: [id], onDelete: Restrict)
  executions   WorkflowExecution[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("workflow_rules")
}

model WorkflowExecution {
  id             String   @id @default(uuid())
  organizationId String
  ruleId         String
  entityType     String
  entityId       String
  result         String   // "SUCCESS" | "FAILED" | "SKIPPED"
  details        Json?
  executedAt     DateTime @default(now())

  updatedAt    DateTime     @default(now()) @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rule         WorkflowRule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([ruleId])
  @@map("workflow_executions")
}

