generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrgPlan {
  trial
  starter
  growth
  scale
}

enum OrgPlanStatus {
  active
  past_due
  cancelled
  trialing
  suspended
  cancelling
  expired
}



enum UserRole {
  CEO
  ADMIN
  BDM
  SALES
  DESIGNER
  QS
}

enum UserStatus {
  Active
  Inactive
}

model Organization {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique // url-safe, lowercase, e.g. "acme-construction"
  industry    String?
  size        String?   // '1-10', '11-50', '51-200', '201+'
  plan        OrgPlan       @default(trial)
  planStatus  OrgPlanStatus @default(active)
  trialEndsAt DateTime?
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  currentPeriodEnd     DateTime? // When current billing period ends (access allowed until this date after cancellation)
  pastDueSince         DateTime? // When org first went past_due — for 7-day grace period enforcement
  country              String?   // ISO 3166-1 alpha-2, e.g. 'GH', 'NG', 'US'
  currency             String    @default("USD") // 'USD' | 'GHS' | 'NGN' | 'KES' | 'ZAR'
  logo                 String?
  timezone             String?
  paystackCustomerId   String?
  paystackSubscriptionCode String?

  // Onboarding drip email tracking
  emailSentDay1   Boolean @default(false)
  emailSentDay3   Boolean @default(false)
  emailSentDay7   Boolean @default(false)

  // Onboarding checklist
  onboardingAddedLead    Boolean @default(false)
  onboardingInvitedTeam  Boolean @default(false)
  onboardingSetPipeline  Boolean @default(false)
  onboardingCompleted    Boolean @default(false)
  demoDataSeeded         Boolean @default(false)

  users           User[]
  leads           Lead[]
  clients         Client[]
  projects        Project[]
  activities      Activity[]
  files           File[]
  stageHistory    StageHistory[]
  projectStatusHistory ProjectStatusHistory[]
  costLogs        CostLog[]
  aiSettings      AISettings?
  auditLogs       AuditLog[]
  rolePermissions RolePermission[]
  teams           Team[]
  pipelineStages  PipelineStage[]
  dropdownOptions DropdownOption[]
  serviceTypes    ServiceType[]
  leadReps        LeadRep[]
  leadTeamMembers LeadTeamMember[]
  tasks           Task[]
  taskTypes       TaskType[]
  notifications   Notification[]
  contacts        Contact[]
  serviceItems    ServiceItem[]
  quotes          Quote[]
  quoteSettings   QuoteSettings?
  timeEntries     TimeEntry[]
  userRates       UserRate[]
  projectBudgets  ProjectBudget[]
  projectAssignments ProjectAssignment[]
  customFieldDefinitions CustomFieldDefinition[]
  customFieldValues      CustomFieldValue[]
  forecastTargets        ForecastTarget[]
  dashboardLayouts       DashboardLayout[]
  aiAnalyticsReports     AIAnalyticsReport[]
  workflowRules          WorkflowRule[]
  workflowExecutions     WorkflowExecution[]
  leadForms              LeadForm[]
  leadFormSubmissions    LeadFormSubmission[]
  products               Product[]
  tenantSettings         TenantSettings?
  quickBooksConnections  QuickBooksConnection[]
  quickBooksSyncs        QuickBooksSync[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@map("organizations")
}

model Lead {
  id                String    @id @default(uuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  contactName       String
  company           String
  position          String?
  email             String?
  phone             String?
  expectedValue     Decimal  @db.Decimal(12, 2)
  stage             String
  urgency           String
  source            String?
  channel           String?
  likelyStartDate   DateTime?
  notes             String?
  aiRiskLevel       String? // 'Low', 'Medium', 'High'
  aiSummary         String?
  aiRecommendations String?

  // New fields
  projectName      String?
  contractedValue  Decimal? @db.Decimal(12, 2)
  executingCompany String?

  // Time tracking for dashboard metrics
  quoteSentAt  DateTime? // When quote was sent (moved to 'Quoted' stage)
  dealClosedAt DateTime? // When deal was won or lost

  // Assignment
  assignedToId String?
  assignedTo   User?   @relation("LeadAssignments", fields: [assignedToId], references: [id], onDelete: SetNull)

  // Flexible team members (replaces fixed designer/qs fields)
  teamMembers LeadTeamMember[]

  // Client relationship (for repeat business - link lead to existing client)
  clientId String?
  client   Client? @relation("ClientLeads", fields: [clientId], references: [id], onDelete: SetNull)

  // Service type
  serviceTypeId String?
  serviceType   ServiceType? @relation(fields: [serviceTypeId], references: [id], onDelete: SetNull)

  // Conversion tracking (set when lead is converted)
  convertedToClientId String?
  convertedToClient   Client? @relation("LeadConversion", fields: [convertedToClientId], references: [id], onDelete: SetNull)

  // Project relationship
  project Project?

  // Reps
  reps LeadRep[]

  // Quotes
  quotes Quote[]

  // Activities
  activities Activity[]

  // Files
  files File[]

  // Stage history
  stageHistory StageHistory[]

  // Lead contacts
  leadContacts LeadContact[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([assignedToId])
  @@index([clientId])
  @@index([serviceTypeId])
  @@index([stage])
  @@index([updatedAt])
  @@index([likelyStartDate])
  @@index([quoteSentAt])
  @@index([dealClosedAt])
  @@index([deletedAt])
  @@map("leads")
}

model LeadRep {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId         String
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  name           String
  phone          String?
  email          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([leadId])
  @@map("lead_reps")
}

model LeadTeamMember {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId         String
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("LeadTeamMemberships", fields: [userId], references: [id], onDelete: Cascade)
  roleLabel      String       // e.g. "Designer", "Backend Developer", "QS"
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([leadId])
  @@index([userId])
  @@map("lead_team_members")
}

model ServiceType {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  leads          Lead[]

  serviceItems   ServiceItem[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("service_types")
}

model Activity {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Polymorphic - can be linked to Lead, Client, or Project
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Structured activity fields
  type         String // 'call' or 'meeting'
  activityDate DateTime // Date of the activity
  activityTime String // Time in HH:MM format
  reason       String // Required: reason for the activity
  notes        String?  @db.Text // Optional notes
  meetingType  String? // For meetings: 'in-person' or 'virtual'

  userId    String
  user      User     @relation("UserActivities", fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([organizationId])
  @@index([leadId, createdAt])
  @@index([clientId, createdAt])
  @@index([projectId])
  @@index([activityDate])
  @@index([createdAt])
  @@map("activities")
}

model File {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Polymorphic - exactly one must be set
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  fileName     String
  originalName String
  mimeType     String
  fileSize     Int
  category     String // 'brief', 'drawing', 'quotation', 'contract', 'meeting_notes', 'other'
  gcpPath      String // GCP Storage path
  uploadedById String
  uploadedBy   User     @relation("FileUploads", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@index([organizationId])
  @@index([leadId])
  @@index([clientId])
  @@index([projectId])
  @@index([createdAt])
  @@map("files")
}

model StageHistory {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId         String
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStage      String? // null for initial creation
  toStage        String // New, Contacted, Quoted, Negotiation, Won, Lost
  changedBy      String
  user           User         @relation("StageChanges", fields: [changedBy], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt

  @@index([organizationId])
  @@index([leadId])
  @@index([toStage])
  @@index([createdAt])
  @@map("stage_history")
}

model Client {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String

  // Contact Information
  email   String?
  phone   String?
  address String? @db.Text
  website String?

  // Individual Contact
  individualName String?
  individualType String? // 'Owner', 'Director', 'Architect', 'Builder', 'PM', 'Other'

  // Classification
  segment  String // 'Enterprise', 'Mid-Market', 'SMB'
  industry String

  // QuickBooks integration
  qbCustomerId String?

  // Financial
  lifetimeRevenue Decimal  @default(0) @db.Decimal(12, 2)

  // Health Status
  status           String  @default("New") // 'New', 'Active', 'Dormant', 'At Risk'
  healthScore      Int? // 0-100
  aiHealthSummary  String? @db.Text
  aiUpsellStrategy String? @db.Text

  // Status Management
  statusOverride       Boolean   @default(false)
  statusOverrideReason String?
  statusLastCalculated DateTime?

  // Engagement Metrics (for AI calculations)
  lastContactDate    DateTime?
  totalProjectCount  Int       @default(0)
  activeProjectCount Int       @default(0)

  // Assignment
  accountManagerId String?
  accountManager   User?   @relation("ClientAssignments", fields: [accountManagerId], references: [id], onDelete: SetNull)

  // Relationships
  projects           Project[]
  leads              Lead[]     @relation("ClientLeads")
  activities         Activity[]
  files              File[]
  convertedFromLeads Lead[]     @relation("LeadConversion")
  contacts           Contact[]
  quotes             Quote[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([segment])
  @@index([status])
  @@index([accountManagerId])
  @@index([deletedAt])
  @@map("clients")
}

model Project {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  leadId String? @unique
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  status            String // 'Planning', 'Active', 'On Hold', 'Completed', 'Cancelled'
  contractedValue   Decimal  @db.Decimal(12, 2)
  endOfProjectValue Decimal? @db.Decimal(12, 2)
  startDate         DateTime?
  completedDate     DateTime?
  description       String?   @db.Text

  estimatedDueDate DateTime?
  closedDate       DateTime?
  riskStatus        String?   @default("On Track")
  estimatedRevenue  Decimal?  @db.Decimal(12, 2)
  totalCost         Decimal   @default(0) @db.Decimal(12, 2)
  executingCompany  String?

  projectManagerId String?
  projectManager   User?   @relation("ProjectManagement", fields: [projectManagerId], references: [id], onDelete: SetNull)

  costLogs      CostLog[]
  files         File[]
  activities    Activity[]
  statusHistory ProjectStatusHistory[]
  timeEntries   TimeEntry[]
  budget        ProjectBudget?
  assignments   ProjectAssignment[]
  quotes        Quote[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([clientId])
  @@index([leadId])
  @@index([status])
  @@index([status, completedDate])
  @@index([contractedValue])
  @@index([deletedAt])
  @@map("projects")
}

model CostLog {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date           DateTime
  category       String
  description    String
  amount         Decimal  @db.Decimal(12, 2)
  createdBy      String
  user           User         @relation("CostLogEntries", fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([projectId])
  @@map("cost_logs")
}

model ProjectStatusHistory {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromStatus     String? // null for initial creation
  toStatus       String // Planning, Active, On Hold, Completed, Cancelled
  changedBy      String
  user           User         @relation("ProjectStatusChanges", fields: [changedBy], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@index([toStatus])
  @@index([createdAt])
  @@map("project_status_history")
}

model User {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  email                  String
  password               String? // Optional to allow migration of existing users
  name                   String
  role                   String
  status                 UserStatus @default(Active)
  isEmailVerified        Boolean   @default(false)
  isOnboarded            Boolean   @default(false) @map("is_onboarded")
  emailVerificationToken        String?   @unique
  emailVerificationTokenExpiry  DateTime?
  resetPasswordToken     String?   @unique
  resetPasswordExpires   DateTime?
  lastLogin              DateTime?
  refreshTokenHash       String?   @db.Text // bcrypt hash of current refresh token (single-use rotation)
  failedLoginAttempts    Int       @default(0)
  lockedUntil            DateTime? // set after N failed logins; clears on successful login
  oauthProvider          String?   // 'google' | 'microsoft'
  oauthProviderId        String?   // provider's unique user ID
  avatarUrl              String?   // profile picture URL

  // Team and hierarchy
  teamName String? // Team identifier for grouping users (Deprecated)

  // New Team structure
  teamId String?
  team   Team?   @relation("TeamMembers", fields: [teamId], references: [id], onDelete: SetNull)

  managedTeams Team[] @relation("ManagerTeams")

  managerId   String? // Reports to this manager (Direct report)
  manager     User?   @relation("ManagerTeam", fields: [managerId], references: [id], onDelete: SetNull)
  teamMembers User[]  @relation("ManagerTeam")

  // Assignments
  assignedLeads    Lead[]             @relation("LeadAssignments")
  leadTeamMemberships LeadTeamMember[] @relation("LeadTeamMemberships")
  assignedClients  Client[]           @relation("ClientAssignments")
  managedProjects  Project[] @relation("ProjectManagement")

  // Audit logs
  auditLogs      AuditLog[] @relation("AuditActor")
  targetedAudits AuditLog[] @relation("AuditTarget")

  // Activities
  activities Activity[] @relation("UserActivities")

  // File uploads
  uploadedFiles File[] @relation("FileUploads")

  // Stage changes
  stageChanges         StageHistory[]         @relation("StageChanges")
  projectStatusChanges ProjectStatusHistory[] @relation("ProjectStatusChanges")

  // Cost log entries
  costLogEntries CostLog[] @relation("CostLogEntries")

  // Tasks
  assignedTasks Task[] @relation("TaskAssignments")
  createdTasks  Task[] @relation("TaskCreation")

  // Time tracking
  timeEntries     TimeEntry[]  @relation("UserTimeEntries")
  userRates       UserRate[]   @relation("UserRates")
  createdQuotes   Quote[]      @relation("QuoteCreator")
  projectAssignments ProjectAssignment[] @relation("ProjectAssignments")

  // Notifications
  notifications              Notification[]            @relation("UserNotifications")
  notificationPreference     NotificationPreference?   @relation("UserNotificationPreferences")

  // Dashboard layout
  dashboardLayout DashboardLayout? @relation("UserDashboardLayout")

  // Workflows
  workflowRules WorkflowRule[] @relation("WorkflowRuleCreator")

  // Lead forms
  assignedForms LeadForm[] @relation("FormAssignee")

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("users")
}

model AISettings {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  defaultProvider          String  @default("anthropic") // 'anthropic', 'openai', 'gemini'
  leadRiskProvider         String?
  clientHealthProvider     String?
  executiveSummaryProvider String?
  chatProvider             String?

  // API Keys (encrypted)
  anthropicApiKey   String? @db.Text
  openaiApiKey      String? @db.Text
  geminiApiKey      String? @db.Text
  anthropicKeyValid Boolean @default(false)
  openaiKeyValid    Boolean @default(false)
  geminiKeyValid    Boolean @default(false)

  // Customizable AI Prompts
  leadRiskPrompt         String? @db.Text
  clientHealthPrompt     String? @db.Text
  executiveSummaryPrompt String? @db.Text
  upsellPrompt           String? @db.Text
  chatPrompt             String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@map("ai_settings")
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("AuditActor", fields: [userId], references: [id], onDelete: Cascade)
  action         String // CREATE_USER, UPDATE_USER, DELETE_USER, PASSWORD_CHANGE, etc.
  targetUserId   String?
  targetUser     User?        @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  details        Json? // Additional context (role changed, field modified, etc.)
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt

  @@index([organizationId])
  @@index([userId])
  @@index([targetUserId])
  @@index([createdAt])
  @@map("audit_logs")
}

model RolePermission {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           String // 'CEO', 'ADMIN', 'BDM', 'SALES', 'DESIGNER', 'QS'
  permission     String // e.g. 'leads:view', 'users:delete'
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, role, permission])
  @@index([organizationId])
  @@index([role])
  @@map("role_permissions")
}

model Team {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  type           String       @default("SALES") // 'SALES', 'SUPPORT', etc.

  // Manager of the team (can oversee multiple teams)
  managerId String?
  manager   User?   @relation("ManagerTeams", fields: [managerId], references: [id], onDelete: SetNull)

  // Members of the team
  members User[] @relation("TeamMembers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("teams")
}

model PipelineStage {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  pipelineType   String       @default("prospective_project") // 'prospective_project' | 'project'
  color          String       @default("bg-gray-500")
  lightColor     String       @default("bg-gray-50")
  border         String       @default("border-gray-200")
  probability    Int          @default(0)
  sortOrder      Int
  isSystem       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, name, pipelineType])
  @@index([organizationId])
  @@index([pipelineType])
  @@map("pipeline_stages")
}

model DropdownOption {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       String // 'urgency', 'activity_type', 'meeting_type', 'file_category', 'cost_category', 'client_segment', 'individual_type', 'project_status', 'project_risk_status'
  value          String // stored value e.g. 'low', 'call'
  label          String // display label e.g. 'Low', 'Call'
  metadata       Json? // extra data: color, icon, etc.
  sortOrder      Int          @default(0)
  isSystem       Boolean      @default(false) // system options cannot be deleted
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, category, value])
  @@index([organizationId])
  @@index([category])
  @@map("dropdown_options")
}

model TaskType {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?  @db.Text
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks        Task[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("task_types")
}

model Task {
  id               String    @id @default(uuid())
  organizationId   String
  title            String
  description      String?
  dueDate          DateTime?
  dueTime          String?
  priority         String    @default("MEDIUM")
  status           String    @default("OPEN")
  entityType       String?
  entityId         String?
  assignedToId     String?
  createdById      String
  taskTypeId       String?
  completedAt      DateTime?
  reminderAt       DateTime?
  completionNote   String?
  uncompleteReason String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedTo   User?        @relation("TaskAssignments", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy    User         @relation("TaskCreation", fields: [createdById], references: [id], onDelete: Restrict)
  taskType     TaskType?    @relation(fields: [taskTypeId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([assignedToId])
  @@index([status])
  @@index([dueDate])
  @@index([entityType, entityId])
  @@map("tasks")
}

model Notification {
  id             String    @id @default(uuid())
  organizationId String
  userId         String
  type           String
  title          String
  message        String    @db.Text
  entityType     String?
  entityId       String?
  read           Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  updatedAt      DateTime  @default(now()) @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id               String   @id @default(uuid())
  userId           String   @unique
  taskAssigned     Boolean  @default(true)
  taskDue          Boolean  @default(true)
  taskOverdue      Boolean  @default(true)
  leadStale        Boolean  @default(true)
  leadStageChanged Boolean  @default(true)
  projectAtRisk    Boolean  @default(true)
  clientDormant    Boolean  @default(true)
  emailDigest      Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  user User @relation("UserNotificationPreferences", fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model Contact {
  id              String   @id @default(uuid())
  organizationId  String
  clientId        String
  firstName       String
  lastName        String
  email           String?
  phone           String?
  jobTitle        String?
  department      String?
  linkedInUrl     String?
  isPrimary       Boolean  @default(false)
  isDecisionMaker Boolean  @default(false)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leads        LeadContact[]

  @@index([organizationId])
  @@index([clientId])
  @@map("contacts")
}

model LeadContact {
  id        String   @id @default(uuid())
  leadId    String
  contactId String
  createdAt DateTime @default(now())

  updatedAt DateTime @default(now()) @updatedAt

  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([leadId, contactId])
  @@index([leadId])
  @@index([contactId])
  @@map("lead_contacts")
}

model ServiceItem {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  serviceTypeId  String?
  unit           String?
  defaultPrice   Decimal? @db.Decimal(10, 2)
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  qbItemId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceType  ServiceType?           @relation(fields: [serviceTypeId], references: [id])
  subtasks     ServiceItemSubtask[]
  quoteLineItems QuoteLineItem[]
  timeEntries  TimeEntry[]

  @@index([organizationId])
  @@map("service_items")
}

model ServiceItemSubtask {
  id            String   @id @default(uuid())
  serviceItemId String
  name          String
  description   String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
