{
  "name": "relon-crm-backend",
  "version": "1.0.0",
  "description": "Relon CRM Backend API with multi-provider AI support",
  "main": "dist/main.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "nest build && npm run sentry:sourcemaps",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "sentry:sourcemaps": "[ -z \"$SENTRY_AUTH_TOKEN\" ] && echo 'Skipping Sentry sourcemaps: SENTRY_AUTH_TOKEN not set' || (sentry-cli sourcemaps inject --org dysruptive-technologies --project node-nestjs ./dist && sentry-cli sourcemaps upload --org dysruptive-technologies --project node-nestjs ./dist)",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google-cloud/storage": "^7.19.0",
    "@google/genai": "^1.40.0",
    "@nestjs-modules/ioredis": "^2.0.2",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/throttler": "^5.2.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@sentry/cli": "^2.58.5",
    "@sentry/nestjs": "^10.43.0",
    "@sentry/profiling-node": "^10.43.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/multer": "^2.0.0",
    "@types/pdfmake": "^0.3.2",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "multer": "^2.0.2",
    "nestjs-pino": "^4.6.0",
    "openai": "^4.26.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "passport-microsoft": "^2.1.0",
    "pdfmake": "^0.3.6",
    "pg": "^8.19.0",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.1",
    "resend": "^6.9.2",
    "rxjs": "^7.8.1",
    "stripe": "^20.3.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.33",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/passport-microsoft": "^2.1.1",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.4.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
